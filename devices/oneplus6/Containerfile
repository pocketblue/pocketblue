ARG from
FROM $from

COPY etc/ /etc/
COPY usr/ /usr/

# kernel
RUN mkdir /boot/dtb && \
    dnf -y remove kernel && \
    dnf -y install kernel kernel-modules-extra && \
    rm -rf /boot/dtb

# firmware
RUN dnf -y install \
    bcm283x-firmware \
    qcom-firmware

# qualcomm tools and libs
RUN dnf -y install \
    libssc \
    hexagonrpc \
    pil-squasher \
    qbootctl \
    bootmac

# audio
RUN dnf -y install \
    alsa-utils \
    alsa-ucm-mobility-sdm845 \
    pulseaudio \
    --exclude pipewire \
    --exclude wireplumber

# usb network
RUN dnf -y install \
    dnsmasq

# other
RUN dnf -y install \
    mobility-tweaks \
    buffyboard

RUN systemctl enable \
    qbootctl.service \
    bootmac-bluetooth.service \
    hexagonrpcd-sdsp.service \
    msm-modem-uim-selection.service
RUN systemctl disable bootc-fetch-apply-updates.timer

COPY fwload/usr/ /usr/

COPY usbnet/etc/ /etc/
COPY usbnet/usr/ /usr/

# clenup
RUN rm -rf /var/log/* && dnf clean all

RUN bootc container lint
