ARG from
FROM $from

COPY etc/ /etc/
COPY usr/ /usr/

RUN mkdir /boot/dtb && \
    dnf -y remove kernel && \
    dnf -y install \
        kernel \
        kernel-modules-extra && \
    dnf -y install \
        bcm283x-firmware \
        mobility-tweaks \
        qcom-firmware \
        pil-squasher \
        buffyboard \
        hexagonrpc \
        qbootctl \
        bootmac \
        libssc && \
    # audio \
    dnf -y remove \
        pipewire \
        pipewire-pulseaudio \
        pipewire-alsa \
        wireplumber && \
    dnf -y install \
        alsa-utils \
        alsa-ucm-mobility-sdm845 \
        pulseaudio && \
    systemctl enable qbootctl.service && \
    systemctl enable bootmac-bluetooth.service && \
    systemctl enable hexagonrpcd-sdsp.service && \
    systemctl enable msm-modem-uim-selection.service && \
    systemctl disable bootc-fetch-apply-updates.timer && \
    dnf clean all

COPY fwload/usr/ /usr/

RUN bootc container lint
