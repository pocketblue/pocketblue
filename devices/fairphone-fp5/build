#!/usr/bin/env bash

set -uexo pipefail

cp -arfT files/usr /usr
cp -arfT files/etc /etc

# Set executable permissions on helper scripts
chmod +x /usr/libexec/fairphone-fp5-debug
chmod +x /usr/libexec/set-bt-mac
chmod +x /usr/libexec/set-modem-sim-slot
chmod +x /usr/libexec/set-display-color-profile

# Install SELinux policy modules (CIL format)
# - iio-sensor-proxy-qrtr: QRTR socket access for Qualcomm SSC sensors
# - systemd-system-control: file context for /etc/systemd/system.control/
#   (systemd-oomd drop-ins that otherwise get mislabeled as etc_t)
semodule -X 400 -i \
    /usr/share/selinux/packages/iio-sensor-proxy-qrtr.cil \
    /usr/share/selinux/packages/systemd-system-control.cil

# packages
dnf -y install \
    atheros-firmware \
    qcom-firmware \
    qrtr \
    rmtfs \
    tqftpserv \
    alsa-ucm-utils \
    bluez \
    libcamera \
    libcamera-ipa

dnf -y install --repo='copr:copr.fedorainfracloud.org:lorbus:misc' \
    hexagonrpc \
    libssc

# Replace stock iio-sensor-proxy with patched build (Do not exit based on sensor events workaround)
dnf -y swap --repo='copr:copr.fedorainfracloud.org:lorbus:misc' \
    iio-sensor-proxy iio-sensor-proxy

systemctl enable \
    hexagonrpcd-adsp-sensorspd.service \
    hexagonrpcd-adsp-rootpd.service \
    rmtfs.service \
    tqftpserv.service

# Mask services that don't apply to mobile ARM devices:
# - bootloader-update: uses bootupd for EFI systems; FP5 uses Android A/B boot
systemctl mask \
    bootloader-update.service

# kernel (from lorbus/misc copr)
dnf -y remove \
    kernel \
    kernel-core \
    kernel-modules \
    kernel-modules-core \
    kernel-modules-extra

dnf -y install --repo='copr:copr.fedorainfracloud.org:lorbus:misc' \
    kernel \
    kernel-core \
    kernel-modules \
    kernel-modules-core \
    kernel-modules-extra

# DT firmware-name references qcm6490/fairphone5/; link RPM-provided firmware
# into the DT-expected path (self-shipped files are already at fairphone5/)
for fw in a660_zap.mbn.xz adsp.mbn.xz cdsp.mbn.xz ipa_fws.mbn.xz wpss.mbn.xz \
          adspr.jsn adsps.jsn adspua.jsn battmgr.jsn cdspr.jsn; do
    ln -sf "../${fw}" "/usr/lib/firmware/qcom/qcm6490/fairphone5/${fw}"
done

KERNEL_SUFFIX=""
QUALIFIED_KERNEL="$(rpm -qa | grep -P 'kernel-(|'"$KERNEL_SUFFIX"'-)(\d+\.\d+\.\d+)' | sed -E 's/kernel-(|'"$KERNEL_SUFFIX"'-)//')"
export DRACUT_NO_XATTR=1
/usr/bin/dracut --no-hostonly --kver "$QUALIFIED_KERNEL" --reproducible -v --add ostree -f "/lib/modules/$QUALIFIED_KERNEL/initramfs.img"
chmod 0600 "/lib/modules/$QUALIFIED_KERNEL/initramfs.img"
