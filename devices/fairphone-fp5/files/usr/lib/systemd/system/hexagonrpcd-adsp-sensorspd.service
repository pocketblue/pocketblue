[Unit]
Description=Daemon to support Qualcomm Hexagon ADSP sensorspd virtual filesystem
After=tqftpserv.service sys-devices-virtual-misc-fastrpc\x2dadsp.device
Requires=tqftpserv.service sys-devices-virtual-misc-fastrpc\x2dadsp.device

[Service]
ExecStart=/usr/bin/hexagonrpcd -f /dev/fastrpc-adsp -d adsp -U sensors -s -R /usr/share/qcom/qcm6490/fairphone5
WorkingDirectory=/
Restart=always
RestartSec=3
User=fastrpc
Group=fastrpc

[Install]
WantedBy=multi-user.target
