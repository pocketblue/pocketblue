; Allow iio-sensor-proxy to use QRTR sockets for Qualcomm SSC sensor access.
; Fedora's iiosensorproxy_t domain lacks permission for qipcrtr_socket,
; passwd_file_t reads (NSS lookups), and cache_home_t dir searches.
(allow iiosensorproxy_t self (qipcrtr_socket (create bind listen accept connect getattr setattr getopt setopt shutdown read write sendto recvfrom append lock ioctl)))
(allow iiosensorproxy_t passwd_file_t (file (getattr map open read)))
(allow iiosensorproxy_t cache_home_t (dir (search)))
(allow iiosensorproxy_t self (capability (dac_override dac_read_search)))
